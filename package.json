{
  "name": "copyeditor",
  "version": "0.1.0",
  "description": "Copyeditor plugin for Obsidian",
  "keywords": [],
  "license": "0-BSD",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
